# Example environment file for `docker run --env-file docker-run.env`.
#
# Usage:
#   docker run --rm -p 9001:9001 \
#     --env-file examples/docker-run.env \
#     -v $(pwd)/examples/rules.policy:/etc/guardrails/rules.policy:ro \
#     ghcr.io/soulwhisper/mcp-guardrails:0.3.4
#
# Every variable here mirrors guardrails/config.py defaults. Uncomment and
# edit the lines you want to override.

# ----- Policy ----------------------------------------------------------------
# failClosed: deny on scanner failure / timeout (recommended for write-capable
# agents). failOpen: allow with a review flag (only when guardrail outage is
# judged less harmful than blocking the agent).
FAILURE_MODE=failClosed

# How HUMAN_REVIEW outcomes are resolved by the aggregator.
#   pass — forward the exchange and emit an audit warning (homelab default).
#   deny — escalate every HUMAN_REVIEW to a hard deny (stricter).
HUMAN_REVIEW_MODE=pass

# ----- Scanners --------------------------------------------------------------
# Max bytes of text fed to any scanner. Tool output beyond this is truncated
# (UTF-8-safe on a character boundary) and the decision is flagged
# `truncated=true` in the audit log. 32KiB covers the attacker-relevant head
# of any payload while keeping P95 latency bounded.
MAX_CONTENT_BYTES=32768

# Mid+tail windows scanned on over-budget payloads (default 8192). Extra
# bytes scanned from the MID and TAIL of an over-budget payload, closing the
# truncation bypass (padding cannot hide an injection past the scanned head,
# nor between the head and tail windows). 0 disables.
SCAN_TAIL_BYTES=8192

# Hard payload cap (default 1048576 / 1MiB). Over-cap payloads are still
# scanned via the head/mid/tail windows AND get a `payload_size`
# HUMAN_REVIEW (scanned/total bytes recorded in audit); HUMAN_REVIEW_MODE
# decides pass+warn vs deny.
SCAN_MAX_PAYLOAD_BYTES=1048576

# Deterministic pattern scanner (hidden ASCII / PII / secrets). Zero ML deps.
ENABLE_REGEX_SCANNER=1

# Structural secret/PII redaction on allowed payloads (replaces matches with
# [REDACTED:<TYPE>] and forwards via the proto `mutated` oneof). Default on.
ENABLE_REDACTION=1
# Also redact HUMAN_REVIEW payloads (default 1): the review verdict is kept
# and the mutated payload rides along, so review-grade PII is masked instead
# of passing through verbatim. 0 restores the legacy pass-unmutated path.
REDACT_ON_REVIEW=1
# Also redact inside params.arguments on the request side. Default off — a
# secret in tool-call params should BLOCK (RegexScanner), not be rewritten.
REDACT_REQUEST_PARAMS=0
# Payload byte cap for redaction (default 262144 / 256KiB); over-cap ->
# skip + redaction_skipped=size in the audit span. Over-cap payloads are
# still scanned by the RegexScanner head/mid/tail scan_windows upstream.
REDACTION_MAX_BYTES=262144

# Per-entry args cap in the Invariant trace window (default 4096). Oversized
# args keep their structure with long string values truncated (rule matchers
# keep working); loop fingerprints are computed from the FULL args.
INVARIANT_ARGS_MAX_BYTES=4096

# gRPC DoS bounds: max message size (default 8388608 / 8MiB) and max
# in-flight RPCs (default 128).
GRPC_MAX_RECV_BYTES=8388608
GRPC_MAX_CONCURRENT_RPCS=128

# Key the audit-log match fingerprints with HMAC-SHA256 (recommended).
# Unset -> plain SHA-256 for high-entropy matches; low-entropy matches
# (email, credit card) always record length only, never a digest.
# AUDIT_HMAC_KEY=change-me

# ONNX PromptGuard semantic scanner. Uses the PUBLIC non-gated ONNX model
# (gravitee-io/Llama-Prompt-Guard-2-86M-onnx) — NO HF_TOKEN needed.
# When the optimum[onnxruntime] package is absent the engine falls back to
# regex-only and logs a warning.
ENABLE_PROMPTGUARD=1

# --- PromptGuard (ONNX, always on) ---
# The ONNX model is public + non-gated — NO HF_TOKEN required.
LF_ONNX_MODEL=gravitee-io/Llama-Prompt-Guard-2-86M-onnx
# model.onnx: full-precision, ~350MB, accuracy 98.01% (default).
# model.quant.onnx: quantized, ~90MB, accuracy 89.89% (smaller, lower recall).
LF_ONNX_FILE=model.onnx
# Supply-chain pin: HF commit sha for hub fetches (matches the Dockerfile
# PG2_REVISION build-arg). Only used when LF_ONNX_LOCAL_DIR is unset;
# override together with LF_ONNX_MODEL.
LF_ONNX_REVISION=45a05fbd5337a864edc608f994911f009c37ca57

# PromptGuard block threshold (0.0-1.0). Score >= threshold -> BLOCK.
LF_PROMPTGUARD_BLOCK_THRESHOLD=0.9

# PromptGuard sliding-window cap per chunk (default 16). The window budget
# adapts to the payload's token length (clamp(ceil(tokens/step)+1, 4,
# PG_MAX_WINDOWS)); each window is one 512-token inference, so this is the
# per-chunk latency bound. Raise for better long-payload coverage, lower for
# tighter P95. Payloads beyond ~PG_MAX_WINDOWS*448+512 tokens still have
# unscanned middle regions (see README coverage matrix).
# PG_MAX_WINDOWS=16

# AgentAlignment is LLM-based (~300-800ms). Default off for homelab; only
# triggered as a second stage when PromptGuard flags HUMAN_REVIEW on the
# response side. Set to 1 to enable the cost-bounded deep-inspection path.
ENABLE_AGENT_ALIGNMENT=0

# --- AgentAlignment LLM config (only used when ENABLE_AGENT_ALIGNMENT=1) ---
# The AgentAlignmentScanner calls an external LLM API to evaluate whether the
# agent has been compromised. Any OpenAI-compatible API works (OpenAI, Azure,
# Together AI, vLLM, Ollama, etc.).
LF_ALIGNMENT_MODEL=meta-llama/Llama-4-Maverick-17B-128E-Instruct-FP8
LF_ALIGNMENT_API_BASE=https://api.together.xyz/v1
# API key for the LLM provider. The scanner reads the key directly from this
# env var. Get one at:
#   Together AI: https://api.together.xyz/settings/keys
#   OpenAI:      https://platform.openai.com/api-keys
# For OpenAI: also set LF_ALIGNMENT_API_BASE=https://api.openai.com/v1
#             and LF_ALIGNMENT_MODEL=gpt-4o (or your model of choice).
# LF_ALIGNMENT_API_KEY=xxxxxxxxxxxxxxx

# ----- Invariant -------------------------------------------------------------
# Sliding-window size for the cross-call toxic-flow trace. 64 covers a typical
# homelab agent tool-use chain; bump for long multi-step plans.
INVARIANT_WINDOW=64

# Max per-route trace windows (default 1024). Traces are isolated per route
# name / first service name; the oldest (LRU) tenant trace is evicted beyond
# this bound.
INVARIANT_MAX_TRACES=1024

# Rule pack source. Point at a file path for hot-reloadable rule packs
# (SIGHUP the server process to reload without dropping connections):
#   kill -HUP 1
INVARIANT_RULES_PATH=/etc/guardrails/rules.policy

# Alternatively, a dotted Python module path (useful for tests / bundled
# packs). Leave commented to use INVARIANT_RULES_PATH above.
# INVARIANT_RULES_MODULE=guardrails.rules.default

# ----- Timing ----------------------------------------------------------------
# Per-scanner deadline in milliseconds. Exceeded -> treated per FAILURE_MODE.
# Keep sidecar < gateway so the sidecar decides first.
SCANNER_TIMEOUT_MS=500

# ----- Networking ------------------------------------------------------------
# Bind address. [::]:9001 listens on all interfaces, IPv4 and IPv6.
# Use 127.0.0.1:9001 to bind loopback only (e.g. for sidecar-on-localhost).
LISTEN_ADDR=[::]:9001

# grpc.aio ThreadPoolExecutor size. Each in-flight RPC occupies one worker;
# raise for high-concurrency deployments.
SERVER_MAX_WORKERS=8

# ----- Observability ---------------------------------------------------------
# OTLP/gRPC endpoint (e.g. http://otel-collector.observability.svc:4317).
# When unset or when the OTel SDK is absent, the sidecar degrades to
# audit-log-only operation.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.observability.svc:4317

# Service name reported on OTel spans/metrics.
OTEL_SERVICE_NAME=mcp-guardrails

# Append-only JSONL audit log. "-" or unset -> stdout. Set to a path for a
# durable, GitOps-friendly audit trail that survives OTel outages.
# AUDIT_LOG_PATH=/var/log/guardrail/audit.jsonl
AUDIT_LOG_PATH=-

# ----- Misc ------------------------------------------------------------------
# Dry-run mode: replace all real scanners with allow-stubs. Use to validate
# wiring without loading ML models.
# GUARDRAIL_DRY_RUN=1
GUARDRAIL_DRY_RUN=0

# Python logging level (DEBUG, INFO, WARNING, ERROR).
LOG_LEVEL=INFO
